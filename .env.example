# Required: Taiga API base URL (no trailing slash)
TAIGA_BASE_URL=https://your-taiga-domain.com/api/v1

# Bootstrap session — server auto-logs in on startup, token stays fixed forever.
# Set all 3 to enable. TAIGA_BOOTSTRAP_TOKEN can be any stable UUID you generate once
# (e.g. via: node -e "console.log(require('crypto').randomUUID())")
TAIGA_BOOTSTRAP_TOKEN=
TAIGA_USERNAME=
TAIGA_PASSWORD=

# HTTP server port
PORT=3000

# Public URL of this MCP server (shown in /.well-known/oauth-protected-resource).
# On Render, you can leave this unset for the first deploy and the app will fall back
# to RENDER_EXTERNAL_URL automatically.
MCP_SERVER_URL=https://your-domain.com

# Session TTL in seconds (default: 86400 = 24 hours)
SESSION_TTL=86400

# CORS: comma-separated origins, or * for all
CORS_ORIGINS=*

# Cache TTL for static lookups (statuses, types, members) in seconds (default: 300 = 5 min)
TAIGA_CACHE_TTL=300

# Per-request timeout in milliseconds (default: 30000 = 30s)
TAIGA_REQUEST_TIMEOUT=30000

# Max retry attempts on transient errors (default: 3)
TAIGA_MAX_RETRIES=3

# Seconds before Taiga token age triggers a refresh (default: 72000 = 20 hours)
TAIGA_TOKEN_REFRESH_THRESHOLD=72000
